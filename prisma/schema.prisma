generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum EmployeeRole {
  ADMIN
  MANAGER
  MEMBER
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum IntegrationKind {
  EMAIL
  CALENDAR
}

model Tenant {
  id        String       @id @default(uuid())
  name      String
  slug      String       @unique
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  createdBy String?
  updatedBy String?

  employees        Employee[]
  telegramBindings TelegramBinding[]
  integrations     IntegrationConnection[]
  agentConfigs     AgentConfig[]
  workflowRuns     WorkflowRun[]
  auditLogs        AuditLog[]
}

model Employee {
  id          String          @id @default(uuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String?         @unique
  email       String
  displayName String
  role        EmployeeRole    @default(MEMBER)
  status      EmployeeStatus  @default(ACTIVE)
  managerId   String?
  manager     Employee?       @relation("OrgHierarchy", fields: [managerId], references: [id], onDelete: SetNull)
  directReports Employee[]    @relation("OrgHierarchy")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   String?
  updatedBy   String?

  telegramBinding TelegramBinding?
  roleAssignments RoleAssignment[]
  integrations    IntegrationConnection[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([managerId])
}

model RoleAssignment {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  roleName   String
  createdAt  DateTime @default(now())

  @@unique([employeeId, roleName])
  @@index([employeeId])
}

model TelegramBinding {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId       String   @unique
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  telegramUserId   String   @unique
  telegramUsername String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
}

model IntegrationConnection {
  id              String           @id @default(uuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId      String?
  employee        Employee?        @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  kind            IntegrationKind
  provider        String
  displayName     String
  encryptedSecret String
  metadata        Json             @default("{}")
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tenantId])
  @@index([provider])
  @@index([tenantId, employeeId])
  @@index([tenantId, kind])
}

model AgentConfig {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentName String
  enabled   Boolean  @default(true)
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, agentName])
  @@index([tenantId])
}

model WorkflowRun {
  id            String              @id @default(uuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  status        WorkflowRunStatus   @default(PENDING)
  correlationId String?
  startedAt     DateTime            @default(now())
  finishedAt    DateTime?
  metadata      Json                @default("{}")

  @@index([tenantId])
  @@index([correlationId])
}

model AuditLog {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId       String?
  actorType     String?
  action        String
  entityType    String
  entityId      String?
  correlationId String?
  payload       Json     @default("{}")
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
  @@index([correlationId])
}
