# Copy to /etc/wilson.env and chmod 600 /etc/wilson.env
# systemd parses KEY=value (no export). Avoid quotes unless needed.

NODE_ENV=production

# Database
DATABASE_URL=postgresql://wilson:password@127.0.0.1:5432/wilson?schema=public

# Ports (defaults match Wilson .env.example)
ADMIN_API_PORT=3000
ORCHESTRATOR_PORT=3020

# Service URLs (same host example)
ORCHESTRATOR_URL=http://127.0.0.1:3020
TASK_AGENT_URL=http://127.0.0.1:3011
CALENDAR_AGENT_URL=http://127.0.0.1:3012
MAIL_AGENT_URL=http://127.0.0.1:3013
ADMIN_API_URL=http://127.0.0.1:3000

# Redis / NATS if used by your deployment
# REDIS_URL=redis://127.0.0.1:6379
# NATS_URL=nats://127.0.0.1:4222

# Telegram (set for production polling bot)
# TELEGRAM_BOT_TOKEN=

# If node is not in /usr/bin (e.g. nvm), set PATH for the service:
# PATH=/home/ubuntu/.nvm/versions/node/v20.18.0/bin:/usr/bin
