[Unit]
Description=Wilson orchestrator
PartOf=wilson.target
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/wilson
EnvironmentFile=/etc/wilson.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/node apps/orchestrator/dist/main.js
Restart=always
RestartSec=5

[Install]
WantedBy=wilson.target
