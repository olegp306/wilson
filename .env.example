# Database
DATABASE_URL=postgresql://wilson:wilson@localhost:5432/wilson?schema=public

# Redis (reserved for future caching / sessions)
REDIS_URL=redis://localhost:6379

# NATS (optional; orchestrator uses HTTP to agents by default)
NATS_URL=nats://localhost:4222

# Admin API — when set, send the same value in the x-admin-key header for protected routes
ADMIN_API_PORT=3000
ADMIN_API_KEY=

# Agents (orchestrator reads these to call mock agents)
TASK_AGENT_URL=http://localhost:3011
CALENDAR_AGENT_URL=http://localhost:3012
MAIL_AGENT_URL=http://localhost:3013

# Orchestrator
ORCHESTRATOR_PORT=3020

# Telegram bot — leave empty to run dev simulation HTTP server; set for real polling
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_BOT_DEV_PORT=3030
ORCHESTRATOR_URL=http://localhost:3020
WILSON_TENANT_ID=11111111-1111-4111-8111-111111111111
WILSON_EMPLOYEE_ID=22222222-2222-4222-8222-222222222222

# Mail — force mock IMAP provider even if DB has integrations (1 = mock)
MAIL_FORCE_MOCK=
# Calendar — force mock provider (1 = mock)
CALENDAR_FORCE_MOCK=

# Optional local IMAP defaults (integration secret on IntegrationConnection is preferred)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# OpenAI — optional; mail summary and draft use heuristics/templates if unset
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Calendar — path to JSON file OR inline JSON (see docs/stage-3.md)
GOOGLE_CALENDAR_CONFIG=

# Logging
LOG_LEVEL=info
